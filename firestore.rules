rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /ads/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;
      allow delete: if true;
    }

    match /clicks/{docId} {
      allow create: if true;
    }
  }
}
